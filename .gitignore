# Data (large files, scraped output, datasets)
data/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# Scraper runtime
.scraper.lock
logs/

# Environment & secrets
.env
.env.*
alerts.conf

# Preprocessing intermediate data & logs
preprocessing/intermediate/
preprocessing/logs/

# BERTopic Stage-1 scratch outputs (memos/ is committed; intermediate/ is not)
figures/bertopic/intermediate/

# Preprocessing caches
preprocessing/cache/

# DuckDB spill files. Created by the default temp_directory at the repo root
# when a query needs to spill to disk and no explicit pragma is set. Stage 12 /
# stage_final_output now point DuckDB at /tmp explicitly, but a crashed run can
# still leave a stray .tmp/ directory behind.
.tmp/

# Preprocessing reference artifacts
preprocessing/reference/raw/
preprocessing/reference/*.parquet

# Exploration intermediate data (regenerated by scripts)
exploration/

# Generated figures (bulk, outside tracked directories)
*.png

# figures/output/: regeneratable data outputs (parquet/csv tables produced by
# scripts in figures/). PDFs are paper-final and stay trackable.
figures/output/*.parquet
figures/output/*.csv

# Exploration archive — only track built static sites (exploration-archive/<ver>/site/site/).
# Source markdown, raw artifacts, figures, tables, scripts stay out of git.
# The archive-guard CI workflow enforces this whitelist on PRs.
exploration-archive/**
!exploration-archive/*/
!exploration-archive/*/site/
!exploration-archive/*/site/site/
!exploration-archive/*/site/site/**

# macOS
.DS_Store

# Windows
Thumbs.db

# IDE
.vscode/
.idea/

# Writing Hub internal config
.writinghub/

# Research scratch workspace (intermediate notes, raw sources)
research/

.pytest_cache

# Claude Code (keep skills tracked)
.claude/*
!.claude/skills/

keys