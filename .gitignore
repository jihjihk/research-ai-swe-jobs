# Data (large files, scraped output, datasets)
data/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# Scraper runtime
.scraper.lock
logs/

# Environment & secrets
.env
.env.*
alerts.conf

# Preprocessing intermediate data & logs
preprocessing/intermediate/
preprocessing/logs/

# Preprocessing caches
preprocessing/cache/

# Preprocessing reference artifacts
preprocessing/reference/raw/
preprocessing/reference/*.parquet

# Exploration intermediate data (regenerated by scripts)
exploration/

# Generated figures (bulk, outside tracked directories)
*.png

# Exploration archive — only track built static sites (exploration-archive/<ver>/site/site/).
# Source markdown, raw artifacts, figures, tables, scripts stay out of git.
# The archive-guard CI workflow enforces this whitelist on PRs.
exploration-archive/**
!exploration-archive/*/
!exploration-archive/*/site/
!exploration-archive/*/site/site/
!exploration-archive/*/site/site/**

# macOS
.DS_Store

# Windows
Thumbs.db

# IDE
.vscode/
.idea/

# Writing Hub internal config
.writinghub/

# Research scratch workspace (intermediate notes, raw sources)
research/

.pytest_cache

# Claude Code (keep skills tracked)
.claude/*
!.claude/skills/

keys