# Root .gitignore excludes *.png globally. Override inside eda/ so Phase A/B/C
# figures can be committed alongside their tables and scripts for audit.
!*.png

# Notebook checkpoints and any editor droppings still ignored.
.ipynb_checkpoints/

# Intermediate caches for the BERTopic / UMAP pipelines in eda/scripts/.
# Large (100s of MB), fully reproducible from data/unified_core.parquet
# by re-running the script that created them. Never needed by the notebook.
artifacts/_*_cache/

# Per-document emergence dumps are intermediate derivatives. The aggregate
# tables in eda/tables/composite_B_v3llm_emergence_*.csv are what the
# notebook consumes; per-doc files only support future ad-hoc queries and
# are regenerated by eda/scripts/composite_B_v3_evolution.py.
artifacts/composite_B_v3llm_per_doc_emergence_*.parquet
